---
import { getCollection } from "astro:content";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import FormattedDate from "../../components/FormattedDate.astro";

export async function getStaticPaths() {
	// getStaticPaths runs in its own scope, so keep any constants it needs local.
	const SHORT_POST_LENGTH = 1000;
	const allPosts = await getCollection("docs");

	const tagSet = new Set<string>(["토막글"]);
	for (const post of allPosts) {
		for (const tag of post.id.split("/").slice(1, -1)) tagSet.add(tag);
		for (const tag of post.data.tags ?? []) tagSet.add(tag);
	}

	return [...tagSet].map((tag) => {
		const posts = allPosts
			.filter((post) => {
				if (tag === "토막글") return (post.body?.length ?? 0) < SHORT_POST_LENGTH;
				return (
					post.id.split("/").slice(1, -1).includes(tag) ||
					(post.data.tags ?? []).includes(tag)
				);
			})
			.sort((a, b) => {
				const da = a.data.lastUpdated ? new Date(a.data.lastUpdated as any).valueOf() : 0;
				const db = b.data.lastUpdated ? new Date(b.data.lastUpdated as any).valueOf() : 0;
				return db - da;
			})
			.map((post) => ({
				title: post.data.title,
				href: `/${post.id}/`,
				folder: post.id.split("/").reverse()[1],
				lastUpdated:
					post.data.lastUpdated instanceof Date ? post.data.lastUpdated : undefined,
				excerpt: post.data.description ?? "",
				body: post.body ?? "",
			}));

		return { params: { tag }, props: { tag, posts } };
	});
}

const { tag, posts } = Astro.props;
---

<StarlightPage frontmatter={{ title: "태그: " + tag }}>
	총 {posts.length}개의 글이 있습니다.
	{tag == "토막글" && <p>양질의 자료를 기록할 수 있도록 노력하겠습니다.</p>}
	<div class="flex flex-col gap-4 ml-3 mr-3">
		{
			posts.map((post) => (
				<div>
					<a class="no-underline" href={post.href}>
						<div class="flex flex-row justify-between">
							<div style="margin-left: 0;" class="flex flex-row gap-2">
								<span class="text-lg title font-bold h-[20px]">{post.title}</span>
								<div
									style="background-color: var(--sl-color-gray-4)"
									class="w-[1px] h-[20px] my-auto"
								/>
								<span style="color: var(--sl-color-gray-3)">{post.folder}</span>
							</div>
							{post.lastUpdated && (
								<div style="margin-right: 0; margin-top: 0">
									<FormattedDate date={new Date(post.lastUpdated)} />
								</div>
							)}
						</div>
						<span class="line-clamp-2 overflow-hidden bg-blue m-0 btext-ellipsis">
							{post.body
								.replace(/>\s|#|- |import.*?;|<[^>]*>?/g, "")
								.slice(0, 400)
								.replace(/```/g, "")
								.replace(/\*\*/g, "")
								.replace(/https:\/\/\S+/g, "")
								.replace(/\[([^\]]+)\]\([^)]+\)/g, "$1") || post.excerpt}
						</span>
					</a>
				</div>
			))
		}
	</div>
</StarlightPage>
